# ============================================================
# GovAI 后端配置（本地开发专用）
# Docker 部署时请修改 项目根/.env，此文件仅供本地 python 直接运行
# ============================================================

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://govai_user:govai_password@localhost:5432/govai_db

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_SECRET_KEY=govai-dev-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── 服务 ──
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Dify 配置 ──
DIFY_MOCK=false
DIFY_BASE_URL=http://host.docker.internal:15001/v1
DIFY_API_KEY=app-x0x62zW8Q1E7Af67BzIbQ2uM
DIFY_DATASET_API_KEY=dataset-02rZJb5w1S39SMUQMXT2sQR2
